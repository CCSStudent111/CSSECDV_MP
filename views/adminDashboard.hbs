<div class="admin-header">
    <h1>Admin Dashboard</h1>
    <p>Welcome, {{user.username}} ({{user.role}})</p>
</div>

{{#if ../error}}
<div class="alert alert-error">{{../error}}</div>
{{/if}}
{{#if ../success}}
<div class="alert alert-success">{{../success}}</div>
{{/if}}

<!-- Create User Section -->
<div class="admin-section">
    <h2>Create Admin/Manager Account</h2>
    <form action="/admin/user/create" method="post" class="admin-form">
        <div class="form-row">
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" placeholder="Enter username" required minlength="3" maxlength="30">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="Enter email" required>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Enter password" required minlength="8" maxlength="64">
                <small>Min 8 chars: uppercase, lowercase, digit, special character</small>
            </div>
            <div class="form-group">
                <label for="role">Role</label>
                <select id="role" name="role" required>
                    <option value="admin">Administrator</option>
                    <option value="manager">Product Manager</option>
                </select>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Create User</button>
    </form>
</div>

<!-- User Management Section -->
<div class="admin-section">
    <h2>User Management</h2>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Join Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each users}}
            <tr>
                <td>{{this.username}}</td>
                <td>{{this.email}}</td>
                <td><span class="role-badge role-{{this.role}}">{{this.role}}</span></td>
                <td><span class="status-badge status-{{this.status}}">{{this.status}}</span></td>
                <td>{{this.joinDate}}</td>
                <td class="actions-cell">
                    <!-- Change Role Form -->
                    <form action="/admin/user/role/{{this._id}}" method="post" class="inline-form">
                        <select name="role" class="role-select">
                            <option value="admin" {{#if (eq this.role "admin")}}selected{{/if}}>Admin</option>
                            <option value="manager" {{#if (eq this.role "manager")}}selected{{/if}}>Manager</option>
                            <option value="customer" {{#if (eq this.role "customer")}}selected{{/if}}>Customer</option>
                        </select>
                        <button type="submit" class="btn btn-sm btn-secondary">Change Role</button>
                    </form>
                    <!-- Delete Form -->
                    <form action="/admin/user/delete/{{this._id}}" method="post" class="inline-form" onsubmit="return confirm('Delete user {{this.username}}?')">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
