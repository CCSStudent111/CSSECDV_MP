<div id="profilebar" class="profilebar">
    <a href="javascript:void(0)" class="closebtn" onclick="toggleProfilebar()">&times;</a>
    <div class="profileinfo">
        {{#if user}}
            <h2>{{user.username}}</h2>
            {{#if user.role}}
            <p style="margin-bottom: 10px;"><span style="background-color: {{#if (eq user.role 'admin')}}#e74c3c{{else}}{{#if (eq user.role 'manager')}}#f39c12{{else}}#3498db{{/if}}{{/if}}; color: white; padding: 3px 8px; border-radius: 12px; font-size: 12px; text-transform: uppercase;">{{user.role}}</span></p>
            {{/if}}
            <p>Email: {{user.email}}</p>
            <p>Member since: {{user.joinDate}}</p>
            <p>Posts: {{user.posts}}</p>
            <p>Comments: {{user.comments}}</p>
            {{#if user.lastLogin}}
            <p style="font-size: 12px; color: #ddd;">Last login: {{user.lastLogin}}</p>
            {{/if}}
            <p><a href="/change-password">Change Password</a></p>
            {{#if (eq user.role "admin")}}
            <p><a href="/admin" style="color: #ff6b6b;">Admin Panel</a></p>
            {{/if}}
            <p><a href="/logout">Logout</a></p>
        {{else}}
            <h2>Not Logged In</h2>
            <p><a href="/login">Login</a></p>
            <p><a href="/register">Register</a></p>
        {{/if}}
    </div>
</div>