<div class="admin-header">
    <h1>Manager Dashboard</h1>
    <p>Welcome, {{user.username}} ({{user.role}})</p>
</div>

{{#if ../error}}
<div class="alert alert-error">{{../error}}</div>
{{/if}}
{{#if ../success}}
<div class="alert alert-success">{{../success}}</div>
{{/if}}


<div class="admin-section">
    <h2>User List</h2>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Join Date</th>
            </tr>
        </thead>
        <tbody>
            {{#each users}}
            <tr>
                <td>{{this.username}}</td>
                <td>{{this.email}}</td>
                <td><span class="role-badge role-{{this.role}}">{{this.role}}</span></td>
                <td><span class="status-badge status-{{this.status}}">{{this.status}}</span></td>
                <td>{{this.joinDate}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<!-- Post Management Section -->
<div class="admin-section">
    <h2>User Management</h2>
    <table class="admin-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Title</th>
                <th>Tags</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th>Likes</th>
                <th>Dislikes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each posts}}
            <tr>
                <td>{{this.author}}</td>
                <td>{{this.title}}</td>
                <td>{{this.tags}}</td>
                <td>{{this.createdAt}}</td>
                <td>{{this.updatedAt}}</td>
                <td>{{this.likes}}</td>
                <td>{{this.dislikes}}</td>
                <td class="actions-cell">
                    <!-- Delete Form -->
                    <form action="/manager/post/delete/{{this._id}}" method="post" class="inline-form" onsubmit="return confirm('Delete post {{this.title}}?')">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
