<div class="content" style="max-width: 500px;">
    <h2>Change Password</h2>
    
    {{#if error}}
    <div class="alert alert-error">{{error}}</div>
    {{/if}}
    {{#if success}}
    <div class="alert alert-success">{{success}}</div>
    {{/if}}

    <form action="/change-password" method="post">
        <div class="form-group">
            <label for="currentPassword">Current Password</label>
            <input type="password" id="currentPassword" name="currentPassword" placeholder="Enter current password" required>
        </div>
        <div class="form-group">
            <label for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password" required minlength="8" maxlength="64">
            <small>Min 8 characters: uppercase, lowercase, digit, special character</small>
        </div>
        <div class="form-group">
            <label for="confirmPassword">Confirm New Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required>
        </div>
        <button type="submit" class="submitpost" style="margin-top: 10px;">Change Password</button>
    </form>
    <br>
    <a href="/" style="color: green;">← Back to Home</a>
</div>
